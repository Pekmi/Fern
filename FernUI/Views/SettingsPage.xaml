<Page
    x:Class="FernUI.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FernUI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <local:StringFormatConverter x:Key="StringFormatConverter"/>
    </Page.Resources>

    <ScrollViewer Padding="32">
        <Grid HorizontalAlignment="Stretch" ColumnSpacing="24" RowSpacing="24">
            <Grid.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="50" />
                </TransitionCollection>
            </Grid.ChildrenTransitions>
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- SECTION MOTEUR VIDÉO (Colonne Gauche, Haute) -->
            <StackPanel Grid.Row="0" Grid.Column="0">
                <TextBlock Text="Moteur Vidéo &amp; Audio" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,12"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="24">
                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Durée du tampon circulaire" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ElementName=BufferSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\}s'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <Slider x:Name="BufferSlider" Minimum="15" Maximum="120" StepFrequency="5" TickFrequency="5" Value="30"/>
                            <TextBlock Text="Définit la longueur de la prise de vue en mémoire vive." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Fréquence d'images (FPS)" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ElementName=FpsSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\} FPS'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <Slider x:Name="FpsSlider" Minimum="10" Maximum="240" StepFrequency="10" TickFrequency="10" Value="60"/>
                            <TextBlock Text="Une fréquence plus élevée rend la vidéo plus fluide mais demande plus de ressources." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>

                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Bitrate de l'encodeur (Mbps)" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ElementName=BitrateSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\} Mbps'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <Slider x:Name="BitrateSlider" Minimum="2" Maximum="50" Value="15"/>
                            <TextBlock Text="Un bitrate plus élevé augmente la qualité mais aussi la taille des fichiers." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SECTION MOTEUR AVANCE (Sous Moteur) -->
                <TextBlock Text="Moteur avancé" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,24,0,12"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="18">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Codec vidéo" Margin="0,0,0,8"/>
                                <ComboBox x:Name="VideoCodecComboBox" HorizontalAlignment="Stretch" SelectionChanged="AdvancedSetting_Changed">
                                    <ComboBoxItem Content="H.264" Tag="H264"/>
                                    <ComboBoxItem Content="HEVC / H.265" Tag="HEVC"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Profil H.264" Margin="0,0,0,8"/>
                                <ComboBox x:Name="EncoderProfileComboBox" HorizontalAlignment="Stretch" SelectionChanged="AdvancedSetting_Changed">
                                    <ComboBoxItem Content="High" Tag="High"/>
                                    <ComboBoxItem Content="Main" Tag="Main"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Text="Contrôle du débit" Margin="0,0,0,8"/>
                            <ComboBox x:Name="RateControlComboBox" HorizontalAlignment="Stretch" SelectionChanged="AdvancedSetting_Changed">
                                <ComboBoxItem Content="VBR contraint" Tag="VBR"/>
                                <ComboBoxItem Content="CBR" Tag="CBR"/>
                                <ComboBoxItem Content="Low delay VBR" Tag="LowDelayVBR"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel>
                            <Grid>
                                <TextBlock Text="Pic VBR maximum" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ElementName=MaxBitrateMultiplierSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\}%'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <Slider x:Name="MaxBitrateMultiplierSlider" Minimum="100" Maximum="400" StepFrequency="25" TickFrequency="25" Value="200"/>
                        </StackPanel>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="GOP" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ElementName=GopSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\}s'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="GopSlider" Minimum="1" Maximum="10" StepFrequency="1" TickFrequency="1" Value="2"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Grid>
                                    <TextBlock Text="B-frames" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ElementName=BFramesSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\}'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="BFramesSlider" Minimum="0" Maximum="4" StepFrequency="1" TickFrequency="1" Value="2"/>
                            </StackPanel>
                        </Grid>

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Qualité / vitesse" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ElementName=QualityVsSpeedSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\}'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="QualityVsSpeedSlider" Minimum="0" Maximum="100" StepFrequency="10" TickFrequency="10" Value="70"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <Grid>
                                    <TextBlock Text="Index encodeur" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding ElementName=EncoderIndexSlider, Path=Value, Converter={StaticResource StringFormatConverter}, ConverterParameter='\{0\}'}" HorizontalAlignment="Right" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="EncoderIndexSlider" Minimum="0" Maximum="8" StepFrequency="1" TickFrequency="1" Value="0"/>
                            </StackPanel>
                        </Grid>

                        <ToggleSwitch x:Name="LowLatencyToggle"
                                      Header="Faible latence"
                                      OffContent="Qualité"
                                      OnContent="Latence basse"
                                      Toggled="AdvancedSetting_Changed"/>
                    </StackPanel>
                </Border>

                <!-- SECTION MICRO (Sous Moteur) -->
                <TextBlock Text="Micro" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,24,0,12"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="16">
                        <StackPanel>
                            <TextBlock Text="Entree micro" Margin="0,0,0,8"/>
                            <ComboBox x:Name="MicrophoneComboBox"
                                      HorizontalAlignment="Stretch"
                                      PlaceholderText="Aucun micro detecte"
                                      DisplayMemberPath="Name"
                                      SelectionChanged="MicrophoneComboBox_SelectionChanged"/>
                        </StackPanel>

                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <TextBlock Text="Signal capte" VerticalAlignment="Center"/>
                                <TextBlock x:Name="MicrophoneLevelText"
                                           Text="0%"
                                           HorizontalAlignment="Right"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                            <ProgressBar x:Name="MicrophoneLevelBar"
                                         Minimum="0"
                                         Maximum="100"
                                         Value="0"
                                         Height="6"
                                         HorizontalAlignment="Stretch"/>
                        </StackPanel>

                        <TextBlock x:Name="MicrophoneStatusText"
                                   Text="Selectionnez un micro pour tester le signal."
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- SECTION RACCOURCIS & CHEMINS (Colonne Droite, Haut) -->
            <StackPanel Grid.Row="0" Grid.Column="1">
                <TextBlock Text="Raccourcis &amp; Chemins" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,12"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="24">
                        <StackPanel>
                            <TextBlock Text="Raccourci Global" Margin="0,0,0,8"/>
                            <TextBox x:Name="HotkeyTextBox"
                                     IsReadOnly="True"
                                     PlaceholderText="Appuyez sur un raccourci"
                                     KeyDown="HotkeyTextBox_KeyDown"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Stockage" Margin="0,0,0,8"/>
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="PathTextBox" Text="C:\Videos\Fern" IsReadOnly="True" VerticalAlignment="Center" FontSize="12"/>
                                <Button Grid.Column="1" Padding="8,4" Click="BrowseButton_Click">
                                    <FontIcon Glyph="&#xE838;" FontSize="14"/>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- SECTION IA (Sous Raccourcis & Chemins) -->
                <TextBlock Text="Intelligence Artificielle" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,24,0,12"/>
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="12" Padding="24" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel Spacing="12">
                        <ToggleSwitch Header="Tri Auto (Modèle Local)" IsOn="True"/>
                        <TextBlock Text="Analyse les clips pour détecter les moments clés automatiquement." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
