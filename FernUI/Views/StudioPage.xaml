<Page
    x:Class="FernUI.Views.StudioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FernUI.Views"
    xmlns:models="using:FernUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="InfoPanelMinWidth">200</x:Double>
        <x:Double x:Key="InfoPanelMaxWidth">450</x:Double>
    </Page.Resources>

    <Grid x:Name="StudioRoot" Padding="32" Background="Transparent" PointerMoved="StudioRoot_PointerMoved">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="100" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel x:Name="HeaderPanel" Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,24">
            <Button x:Name="BackButton" Click="BackButton_Click" 
                    Style="{ThemeResource NavigationBackButtonNormalStyle}" 
                    ToolTipService.ToolTip="Retour à la Galerie"
                    Margin="0,0,16,0"/>
            <TextBlock x:Name="ClipTitleTextBlock" Text="Nom du Clip" 
                       Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold"/>
        </StackPanel>

        <Grid x:Name="WorkspaceGrid" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="PlayerColumn" MinWidth="500"/>
                <ColumnDefinition x:Name="InfoColumn" Width="300" MinWidth="200" MaxWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- COLONNE GAUCHE : Lecteur Vidéo -->
            <Grid x:Name="PlayerPanel" Grid.Column="0" Margin="0,0,24,0">
                <!-- All content (Video + Controls) is now in a single scaling block -->
                <Viewbox x:Name="PlayerViewbox"
                         Stretch="Uniform"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         RenderTransformOrigin="0.5,0.5">
                    <Viewbox.RenderTransform>
                        <CompositeTransform/>
                    </Viewbox.RenderTransform>
                    <Grid Width="1920">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Video (Top Rounded) -->
                        <Border Grid.Row="0" Background="Black" CornerRadius="12,12,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
                            <Grid Width="1920" Height="1080">
                                <MediaPlayerElement x:Name="StudioPlayer"
                                                    AreTransportControlsEnabled="False"
                                                    AutoPlay="False"
                                                    Stretch="Uniform"/>
                                <Border Background="Transparent"
                                        Tapped="VideoSurface_Tapped"
                                        DoubleTapped="VideoSurface_DoubleTapped"
                                        ToolTipService.ToolTip="Lecture / pause"/>
                            </Grid>
                        </Border>

                        <!-- Custom Controls (Stuck to Video, Sharp Corners) -->
                        <Border x:Name="ControlsPanel" Grid.Row="1" Background="#CC000000" Height="96" CornerRadius="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid Margin="24,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- Play/Pause -->
                                    <ColumnDefinition Width="*"/>    <!-- Seek Bar -->
                                    <ColumnDefinition Width="Auto"/> <!-- Volume Group -->
                                    <ColumnDefinition Width="Auto"/> <!-- Fullscreen -->
                                </Grid.ColumnDefinitions>

                                <!-- Play/Pause -->
                                <Button x:Name="PlayPauseButton" 
                                        Grid.Column="0" 
                                        VerticalAlignment="Center"
                                        Click="PlayPauseButton_Click"
                                        Background="Transparent" BorderThickness="0"
                                        Width="64" Height="64">
                                    <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE768;" FontSize="28" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>

                                <!-- Seek Bar -->
                                <Slider x:Name="ProgressSlider" 
                                        Grid.Column="1" 
                                        Margin="32,0" 
                                        VerticalAlignment="Center"
                                        StepFrequency="0.001"
                                        ValueChanged="ProgressSlider_ValueChanged"
                                        Foreground="{ThemeResource SystemControlHighlightAccentBrush}"/>

                                <!-- Volume Group -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,32,0">
                                    <Button x:Name="MuteButton" 
                                            Click="MuteButton_Click"
                                            VerticalAlignment="Center"
                                            Background="Transparent" BorderThickness="0"
                                            Width="64" Height="64">
                                        <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="24" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Slider x:Name="VolumeSlider" 
                                            Width="120" 
                                            VerticalAlignment="Center"
                                            Minimum="0" Maximum="100" Value="30"
                                            ValueChanged="VolumeSlider_ValueChanged"/>
                                </StackPanel>

                                <!-- Fullscreen -->
                                <Button x:Name="FullscreenButton" 
                                        Grid.Column="3" 
                                        Click="FullscreenButton_Click"
                                        VerticalAlignment="Center"
                                        Background="Transparent" BorderThickness="0"
                                        Width="64" Height="64">
                                    <FontIcon x:Name="FullscreenIcon" Glyph="&#xE740;" FontSize="24" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>
                </Viewbox>
            </Grid>

            <!-- COLONNE DROITE : Mixage & Infos -->
            <Grid x:Name="InfoPanel" Grid.Column="1">
                <Border Background="{ThemeResource LayerFillColorDefaultBrush}" 
                        CornerRadius="12" Padding="24" 
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                        BorderThickness="1"
                        VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0">
                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Studio" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DurationText"
                                           Grid.Column="1"
                                           Text="00:00"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           TextWrapping="WrapWholeWords"/>
                            </Grid>
                            <TextBlock Text="Pistes audio" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,0,0,12"/>
                            <StackPanel Margin="0,0,0,16">
                                <Grid Margin="0,0,0,4">
                                    <TextBlock Text="Master" VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="MasterVolumeText"
                                               Text="30%"
                                               HorizontalAlignment="Right"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </Grid>
                                <Slider x:Name="MasterVolumeSlider"
                                        Minimum="0"
                                        Maximum="100"
                                        Value="30"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <!-- Console de Mixage -->
                        <ListView x:Name="AudioTracksListView" Grid.Row="1" SelectionMode="None" VerticalAlignment="Top">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:AudioTrack">
                                    <Grid Margin="0,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Glyph="{x:Bind Icon}" Margin="0,0,16,0" Grid.RowSpan="2" VerticalAlignment="Center" FontSize="20" Opacity="0.7"/>
                                        <TextBlock Text="{x:Bind Name}" Grid.Column="1" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                        <Slider Grid.Row="1" Grid.Column="1" Value="{x:Bind Volume, Mode=TwoWay}" Minimum="0" Maximum="100" Margin="0,-4,0,0"/>
                                        <ProgressBar Grid.Row="1" Grid.Column="1" Value="{x:Bind PeakLevel}" VerticalAlignment="Bottom" Height="2" Margin="0,0,0,4" Foreground="{ThemeResource SystemControlHighlightAccentBrush}" Background="Transparent"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <StackPanel Grid.Row="2" Margin="0,24,0,0">
                            <Grid ColumnSpacing="12" Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="Partager" HorizontalAlignment="Stretch" Padding="0,12"/>
                                <Button x:Name="ExportButton"
                                        Grid.Column="1"
                                        Content="Exporter"
                                        HorizontalAlignment="Stretch"
                                        Padding="0,12"
                                        Click="ExportButton_Click"/>
                            </Grid>
                            <Button x:Name="SaveButton"
                                    Style="{StaticResource AccentButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Padding="0,12"
                                    Click="SaveButton_Click"
                                    RenderTransformOrigin="0.5,0.5">
                                <Button.RenderTransform>
                                    <CompositeTransform/>
                                </Button.RenderTransform>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                    <FontIcon x:Name="SaveButtonIcon" Glyph="&#xE74E;" FontSize="16"/>
                                    <TextBlock x:Name="SaveButtonText" Text="Sauvegarder"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
