<Page
    x:Class="FernUI.Views.GalleryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:FernUI.Views"
    xmlns:models="using:FernUI.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent"
    PreviewKeyDown="Page_KeyDown">

    <Page.Resources>
        <SolidColorBrush x:Key="GallerySurfaceBrush" Color="#18FFFFFF"/>
        <SolidColorBrush x:Key="GalleryMediaSurfaceBrush" Color="#12000000"/>

        <DataTemplate x:Key="ClipCardTemplate" x:DataType="models:ClipModel">
            <Grid x:Name="CardRoot" 
                  Margin="0,0,0,16" 
                  PointerEntered="CardRoot_PointerEntered" 
                  PointerExited="CardRoot_PointerExited"
                  Tapped="CardRoot_Tapped"
                  RenderTransformOrigin="0.5,0.5"
                  IsTabStop="True">
                <Grid.RenderTransform>
                    <CompositeTransform/>
                </Grid.RenderTransform>

                <Grid.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="Générer un titre avec l'IA" Click="MenuAnalyzeAi_Click">
                            <MenuFlyoutItem.Icon>
                                <FontIcon Glyph="&#xE945;"/> <!-- Magic wand/Sparkle icon -->
                            </MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Grid.ContextFlyout>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Zone Media -->
                <Border CornerRadius="12" Height="{Binding CardHeight}" Background="{StaticResource GallerySurfaceBrush}">
                    <Grid>
                        <!-- Image Statique -->
                        <Grid Background="{StaticResource GalleryMediaSurfaceBrush}">
                            <FontIcon Glyph="{Binding ThumbnailIcon}" FontSize="32" Opacity="0.2"/>
                            <Image x:Name="PreviewImageControl"
                                   Source="{Binding PreviewImage}"
                                   Stretch="UniformToFill"
                                   Opacity="0"/>
                        </Grid>

                        <Border x:Name="SelectionBorder"
                                Canvas.ZIndex="10"
                                IsHitTestVisible="False"
                                BorderBrush="{ThemeResource SystemControlHighlightAccentBrush}"
                                BorderThickness="3"
                                CornerRadius="12"
                                Opacity="0"/>

                        <Border x:Name="NewClipHighlightBorder"
                                IsHitTestVisible="False"
                                BorderBrush="{ThemeResource SystemControlHighlightAccentBrush}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Opacity="0"/>
                        
                        <!-- CORRECTIF BADGE DURÉE -->
                        <Border x:Name="DurationBadge" 
                                Visibility="{Binding DurationVisibility}"
                                VerticalAlignment="Bottom" HorizontalAlignment="Right" 
                                Margin="8" Background="#80000000" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="{Binding Duration}" Foreground="White" FontSize="11" FontWeight="Medium"/>
                        </Border>

                        <Border Visibility="{Binding ResolutionVisibility}"
                                VerticalAlignment="Top" HorizontalAlignment="Left"
                                Margin="8" Background="#80000000" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="{Binding Resolution}" Foreground="White" FontSize="11" FontWeight="Medium"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Infos -->
                <StackPanel Grid.Row="1" Margin="16,12,16,0" HorizontalAlignment="Stretch">
                    <TextBox Text="{Binding Title, Mode=OneWay}" FontSize="14" FontWeight="SemiBold" MaxLength="100" BorderThickness="0" Background="Transparent" Padding="0" MinHeight="0" Margin="0,-4,0,-4" TextAlignment="Center" HorizontalAlignment="Stretch" TextWrapping="Wrap" LostFocus="TitleTextBox_LostFocus" KeyDown="TitleTextBox_KeyDown" Tapped="TitleTextBox_Tapped"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Date}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer Padding="32" Background="Transparent">
        <StackPanel>
            <StackPanel.ChildrenTransitions>
                <TransitionCollection>
                    <EntranceThemeTransition FromVerticalOffset="100" />
                </TransitionCollection>
            </StackPanel.ChildrenTransitions>
            
            <!-- BANDEAU DE CONTRÔLE (80% Recherche / 20% Date) -->
            <Grid ColumnSpacing="12" Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="8*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <AutoSuggestBox x:Name="SearchBox" 
                                QueryIcon="Find" 
                                Height="32"
                                FontSize="16"
                                FontWeight="Light"
                                VerticalAlignment="Center"
                                TextChanged="SearchBox_TextChanged"
                                QuerySubmitted="SearchBox_QuerySubmitted"/>

                <Button Grid.Column="1" 
                        x:Name="DateFilterButton"
                        Content="Date" 
                        Click="DateFilterButton_Click"
                        Height="32"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="D" Modifiers="Control"/>
                    </Button.KeyboardAccelerators>
                </Button>
            </Grid>

            <Grid x:Name="TimelinePanel" Height="0" Opacity="0" Margin="0,0,0,0">
                <Grid.Resources>
                    <Storyboard x:Name="ShowTimelineStoryboard">
                        <DoubleAnimation Storyboard.TargetName="TimelinePanel" 
                                         Storyboard.TargetProperty="Height" 
                                         To="168" 
                                         Duration="0:0:0.3"
                                         EnableDependentAnimation="True">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="TimelinePanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.3"/>
                    </Storyboard>
                    <Storyboard x:Name="HideTimelineStoryboard">
                        <DoubleAnimation Storyboard.TargetName="TimelinePanel" 
                                         Storyboard.TargetProperty="Height" 
                                         To="0" 
                                         Duration="0:0:0.3"
                                         EnableDependentAnimation="True">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseIn"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="TimelinePanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2"/>
                    </Storyboard>
                </Grid.Resources>

                <Border Background="{StaticResource GallerySurfaceBrush}" CornerRadius="10" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Margin="0,0,0,18" Padding="24,14">
                    <Grid>
                        <!-- Zone de courbe dynamique (Sera tracée en code-behind) -->
                        <Canvas x:Name="GraphCanvas" Height="60" VerticalAlignment="Top" Margin="32,0" Opacity="1"/>

                        <!-- Timeline (Axe) -->
                        <Grid x:Name="TimelineTrack" Height="72" VerticalAlignment="Bottom" Margin="16,0">
                            <!-- Barre de fond -->
                            <Rectangle Height="2" Fill="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                            
                            <!-- Zone de sélection colorée et draggable -->
                            <Grid x:Name="SelectedRangeContainer"
                                  Height="56"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left"
                                  Background="Transparent"
                                  PointerPressed="RangeBar_PointerPressed"
                                  PointerMoved="RangeBar_PointerMoved"
                                  PointerReleased="RangeBar_PointerReleased">
                                <Rectangle Height="4" Fill="{ThemeResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center"/>
                            </Grid>
                            
                            <Canvas x:Name="TimelineCanvas">
                                <!-- Point Début -->
                                <Grid x:Name="StartHandle" Canvas.Left="0" Canvas.Top="16" 
                                      PointerPressed="Handle_PointerPressed" 
                                      PointerMoved="Handle_PointerMoved" 
                                      PointerReleased="Handle_PointerReleased"
                                      Background="Transparent" Width="40" Height="40">
                                    <Ellipse Width="16" Height="16" Fill="White" Stroke="{ThemeResource SystemControlHighlightAccentBrush}" StrokeThickness="3" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>

                                <!-- Point Fin -->
                                <Grid x:Name="EndHandle" Canvas.Left="800" Canvas.Top="16" 
                                      PointerPressed="Handle_PointerPressed" 
                                      PointerMoved="Handle_PointerMoved" 
                                      PointerReleased="Handle_PointerReleased"
                                      Background="Transparent" Width="40" Height="40">
                                    <Ellipse Width="16" Height="16" Fill="White" Stroke="{ThemeResource SystemControlHighlightAccentBrush}" StrokeThickness="3" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Grid>

                                <TextBlock x:Name="StartDateText"
                                           Canvas.Top="52"
                                           Width="120"
                                           Text="Début"
                                           FontSize="10"
                                           TextAlignment="Center"
                                           FontWeight="SemiBold"
                                           IsHitTestVisible="False"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock x:Name="EndDateText"
                                           Canvas.Top="52"
                                           Width="120"
                                           Text="Fin"
                                           FontSize="10"
                                           TextAlignment="Center"
                                           FontWeight="SemiBold"
                                           IsHitTestVisible="False"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            </Canvas>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Border x:Name="EmptyState"
                    Visibility="Collapsed"
                    Background="{StaticResource GallerySurfaceBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="28"
                    Margin="0,8,0,0">
                <StackPanel Spacing="8">
                    <FontIcon Glyph="&#xE714;" FontSize="28" Opacity="0.55"/>
                    <TextBlock Text="Aucun clip dans le dossier Fern" Style="{ThemeResource BodyStrongTextBlockStyle}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyStatePathText"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Style="{ThemeResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Border>

            <!-- GRILLE MASONRY -->
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="Column0" Grid.Column="0">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition />
                            <RepositionThemeTransition />
                            <EntranceThemeTransition FromVerticalOffset="40" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>
                
                <StackPanel x:Name="Column1" Grid.Column="1">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition />
                            <RepositionThemeTransition />
                            <EntranceThemeTransition FromVerticalOffset="60" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>
                
                <StackPanel x:Name="Column2" Grid.Column="2">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition />
                            <RepositionThemeTransition />
                            <EntranceThemeTransition FromVerticalOffset="80" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
